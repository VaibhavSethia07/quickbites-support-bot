# Copy to .env and fill in before running your bot locally.

# Claude API (we will provide a capped key; any Claude model is fine).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Simulator base URL (we will send this to you).
SIMULATOR_BASE_URL=https://quickbites-simulator.example.com

# Your candidate passphrase (we will send this to you). This is the same
# value you use to sign in on /candidate/login, and what you send in the
# `X-Candidate-Token` header for prod runs. Example:
# CANDIDATE_TOKEN=apple-car-philips-moon
CANDIDATE_TOKEN=replace-me